---
import Layout from '../layouts/Layout.astro';
import TaskApp from '../components/TaskApp.astro';
---
<button onclick="toggleDark()" style="position: fixed; top: 20px; right: 20px;">
  🌙
</button>

<script is:inline>
  function toggleDark() {
    document.body.classList.toggle("dark");
  }
</script>
<Layout>
  <div class="app">
    
    <!-- IZQUIERDA -->
    <div class="sidebar">
      <h1>Mi App</h1>
      <p>Organizá tus tareas fácil 🚀</p>
    </div>

    <!-- DERECHA -->
    <div class="content">
      <section>
        <h2>📝 Tareas</h2>
        <TaskApp />
      </section>

      <section>
        <h2>ℹ️ Info</h2>
        <p>Proyecto hecho con Astro.</p>
      </section>
    </div>

  </div>
</Layout>